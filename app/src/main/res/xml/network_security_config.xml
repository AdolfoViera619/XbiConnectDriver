<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Production traffic uses HTTPS exclusively. The two domains we contact
      (api-xbi-main.xbiplus.com and connect.xbiplus.com) keep their default
      strict policy — no cleartext, no user-installed CAs.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!--
      Local development against the Chatwoot Docker on the developer's Mac.
      The Mac's LAN address shifts with DHCP; we allow the whole private
      192.168.0.0/16 range and 10.0.0.0/8 so the toggle keeps working when
      the IP moves. This block ONLY relaxes cleartext for those hosts —
      anywhere else still requires HTTPS.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168.100.8</domain>
        <domain includeSubdomains="true">192.168.100.4</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
